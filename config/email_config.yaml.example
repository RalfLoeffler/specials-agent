# Copy this file to email_config.yaml and fill in real values.
gmail_user: "youraddress@gmail.com"
auth_mode: "app_password"  # or "password"
gmail_app_password: "your_16_char_app_password"
# gmail_password: "your_regular_password_here"
smtp_host: "smtp.gmail.com"
smtp_port: 587
smtp_use_tls: true
email_subject: "Weekly grocery specials report"
email_test_subject: "Email test - grocery specials checker"
report_verbose: false
to_email: "where_to_send_report@gmail.com"
# Optional indexed recipient list for per-item routing.
# If this is set, index 0 is the first address, index 1 the second, and so on.
# Watchlist items can then use email_index or email_indices to target entries here.
# to_emails:
#   - "where_to_send_report@gmail.com"
#   - "somebody_else@gmail.com"
